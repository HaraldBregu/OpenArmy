{
  "name": "@hb_army/openarmy",
  "version": "2.0.0",
  "description": "Agentic AI runtime for configurable agents, tools, skills, isolated workspaces, scheduling, and gateways",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "oa": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "bash tests/smoke.sh",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build && npm run typecheck && npm run lint"
  },
  "files": [
    "dist/",
    "README.md",
    "docs/"
  ],
  "keywords": [
    "agents",
    "ai-runtime",
    "tools",
    "skills",
    "openarmy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.19.11",
    "eslint": "^8.54.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
