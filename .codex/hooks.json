{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$(git rev-parse --show-toplevel)/.codex/hooks/auto-add-commit-push.sh\"",
            "statusMessage": "Auto committing changes"
          }
        ]
      }
    ]
  }
}
